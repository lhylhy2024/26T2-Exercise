    "import os\n",
    "# 定义项目目录列表\n",
    "dirs = [\n",
    "    \"code\",\n",
    "    \"data/raw\",\n",
    "    \"data/clean\",\n",
    "    \"data/feature\",\n",
    "    \"img\",\n",
    "    \"model_output\",\n",
    "    \"report\"\n",
    "]\n",
    "\n",
    "# 循环创建目录\n",
    "for dir_path in dirs:\n",
    "    os.makedirs(dir_path, exist_ok=True)\n",
    "    print(f\"目录创建成功：{dir_path}\")"
   ]
